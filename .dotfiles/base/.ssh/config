Host github.com
  hostname ssh.github.com
  port 443
  user git

Host *
  addKeysToAgent no
  compression no
  controlMaster no
  controlPath ~/.ssh/master-%r@%n:%p
  controlPersist no
  forwardAgent no
  hashKnownHosts no
  serverAliveCountMax 3
  serverAliveInterval 0
  userKnownHostsFile ~/.ssh/known_hosts
